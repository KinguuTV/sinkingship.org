---
interface Props {
  title?: string;
}

const { title = "Media Showcase" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Responsive media showcase website" />
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/global.css">
  </head>
  <body>
    <slot />
  </body>
</html>