---
import BaseLayout from "../layouts/BaseLayout.astro";
import Showcase from "../components/Showcase.astro";
import ButtonBar from "../components/ButtonBar.astro";
import { contentItems } from "../data/content";
---

<BaseLayout title="SinkingShip">
  <main class="site-shell">
    <div class="site-frame">
      <header class="top-banner">
        <div class="marquee-wrap">
          <marquee scrollamount="7">
            WELCOME TO SINKINGSHIP.ORG ★ GIFS ★ VIDEOS ★ MEMES ★ RANDOM CHAOS ★
          </marquee>
        </div>
      </header>

      <section class="showcase-wrap">
        <Showcase items={contentItems} />
      </section>

      <footer class="buttons-wrap">
        <ButtonBar />
      </footer>
    </div>
  </main>
</BaseLayout>

<style>
  .site-shell {
    height: 100vh;
    width: 100%;
    padding: 20px;
    box-sizing: border-box;
    display: flex;
    justify-content: center;
    align-items: center;
    font-family: Tahoma, Verdana, Arial, sans-serif;
    background:
      radial-gradient(circle at top, #dff3ff 0%, #b8d8f5 35%, #8eb6dc 70%, #6f97c4 100%);
    overflow: hidden;
  }

  .site-frame {
    width: min(100%, 980px);
    height: min(92vh, 920px);
    display: grid;
    grid-template-rows: 56px minmax(0, 1fr) 110px;
    gap: 16px;
    min-height: 0;
    min-width: 0;
  }

  .top-banner {
    width: 100%;
    min-width: 0;
    min-height: 0;
    height: 56px;
    display: flex;
    align-items: stretch;
  }

  .marquee-wrap {
    width: 100%;
    height: 100%;
    min-width: 0;
    display: flex;
    align-items: center;
    box-sizing: border-box;
    border: 3px solid #244b7f;
    border-radius: 16px;
    background: linear-gradient(180deg, #2d74c4 0%, #184b8e 100%);
    color: white;
    padding: 0 10px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.3);
    box-shadow:
      0 0 0 2px #dff0ff inset,
      0 10px 20px rgba(0, 0, 0, 0.15);
    overflow: hidden;
  }

  .marquee-wrap marquee {
    width: 100%;
    line-height: 1;
  }

  .showcase-wrap {
    width: 100%;
    height: 100%;
    min-width: 0;
    min-height: 0;
    display: flex;
    align-items: stretch;
    justify-content: stretch;
    overflow: hidden;
  }

  .buttons-wrap {
    width: 100%;
    height: 110px;
    min-width: 0;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .site-shell {
      padding: 12px;
    }

    .site-frame {
      width: 100%;
      height: 100%;
      grid-template-rows: 46px minmax(0, 1fr) 92px;
      gap: 12px;
    }

    .top-banner {
      height: 46px;
    }

    .buttons-wrap {
      height: 92px;
    }

    .marquee-wrap {
      font-size: 10px;
      border-radius: 12px;
      padding: 0 8px;
    }
  }
</style>